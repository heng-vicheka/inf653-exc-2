<div class="dashboard-header">
  <div>
    <h1>Dashboard</h1>
    <p>Welcome back, <strong>{{session.user.username}}</strong>! Manage your fuel records below.</p>
  </div>
  <a href="/records/create" class="btn btn-primary">+ New Record</a>
</div>

{{#if records}}
  <div class="records-table-container">
    <table class="records-table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Vehicle Type</th>
          <th>Liters</th>
          <th>Distance (km)</th>
          <th>Total Cost</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each records}}
          <tr>
            <td>{{this.date}}</td>
            <td>{{this.vehicleType}}</td>
            <td>{{this.liters}}</td>
            <td>{{this.distanceKm}}</td>
            <td>${{this.totalCost}}</td>
            <td>
              <a href="/records/{{this.id}}/edit" class="btn btn-sm btn-info">Update</a>
              <form method="POST" action="/records/{{this.id}}/delete" style="display:inline;">
                <input type="hidden" name="_csrf" value="{{@root.csrfToken}}">
                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this record?');">Delete</button>
              </form>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
{{else}}
  <div class="placeholder-card">
    <p>No fuel records yet. <a href="/records/create">Create your first record</a></p>
  </div>
{{/if}}
